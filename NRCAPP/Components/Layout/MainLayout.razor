@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

@if (IsEntryPage)
{
    <main class="entry-main" dir="rtl">
        @Body
    </main>
}
else
{
    <div class="app-shell" dir="rtl">
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-mark">ن</div>
                <div>
                    <div class="brand-title">نقطة</div>
                    <div class="brand-subtitle">مركز تنسيق الإغاثة</div>
                </div>
            </div>

            <nav class="nav-links" aria-label="التنقل الرئيسي">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="nav-icon">⌂</span>
                    بوابة الدخول
                </NavLink>

                @if (IsOrg)
                {
                    <NavLink class="nav-link" href="org/dashboard">
                        <span class="nav-icon">م</span>
                        مسار المؤسسة
                    </NavLink>
                }

                @if (IsCitizen)
                {
                    <NavLink class="nav-link" href="citizen/profile">
                        <span class="nav-icon">و</span>
                        ملف المواطن
                    </NavLink>
                }

                <NavLink class="nav-link" href="aid-distribution">
                    <span class="nav-icon">✓</span>
                    الجدولة والتوزيع
                </NavLink>

                <NavLink class="nav-link" href="gap-detector">
                    <span class="nav-icon">!</span>
                    كشف الفجوات
                </NavLink>

                <NavLink class="nav-link" href="analytics">
                    <span class="nav-icon">▦</span>
                    التحليلات
                </NavLink>

                <NavLink class="nav-link" href="volunteers">
                    <span class="nav-icon">●</span>
                    المتطوعون
                </NavLink>

                @if (IsAdmin)
                {
                    <NavLink class="nav-link" href="admin/dashboard">
                        <span class="nav-icon">إ</span>
                        مسؤول البرنامج
                    </NavLink>
                }

                <NavLink class="nav-link" href="settings">
                    <span class="nav-icon">⚙</span>
                    الإعدادات
                </NavLink>
            </nav>

            <div class="sidebar-user">
                <span class="user-avatar">@UserInitial</span>
                <span>@UserLabel</span>
            </div>
        </aside>

        <main class="main-panel">
            <header class="topbar">
                <div class="topbar-title">
                    <h1>@CurrentTitle</h1>
                    <span class="clock">@ClockText</span>
                </div>

                <div class="topbar-actions">
                    <div class="status-pill" aria-live="polite">
                        <span class="status-dot @(IsOffline ? "offline" : "online")"></span>
                        <span>@(IsOffline ? "غير متصل - حفظ محلي للبيانات" : "متصل - تمت المزامنة")</span>
                    </div>
                    <button type="button" class="toggle-button" @onclick="ToggleOffline">
                        وضع الاتصال
                    </button>
                </div>
            </header>

            @if (IsOffline)
            {
                <div class="offline-banner">
                    وضع عدم الاتصال مفعل. يتم حفظ البلاغات محلياً وسيتم رفعها عند عودة الشبكة.
                </div>
            }

            <article class="content">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    حدث خطأ غير متوقع.
    <a href="." class="reload">إعادة تحميل</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool IsOffline { get; set; }
    private string CurrentTitle { get; set; } = "نقطة - بوابة الدخول";
    private bool IsEntryPage { get; set; } = true;
    private string ClockText { get; set; } = FormatLocalTime();
    private bool IsOrg { get; set; }
    private bool IsCitizen { get; set; }
    private bool IsAdmin { get; set; }
    private string UserInitial { get; set; } = "م";
    private string UserLabel { get; set; } = "زائر";
    private readonly CancellationTokenSource clockCancellation = new();

    protected override void OnInitialized()
    {
        SetCurrentPage();
        SetUserContext();
        Navigation.LocationChanged += HandleLocationChanged;
        _ = RunClockAsync();
    }

    private void SetUserContext()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            var actorType = user.FindFirst("actor_type")?.Value;
            IsOrg = actorType == "Organization";
            IsAdmin = actorType == "Admin";
            IsCitizen = false;

            var name = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
            UserInitial = name.Length > 0 ? name[..1] : "م";
            UserLabel = IsOrg ? name : (IsAdmin ? "مسؤول النظام" : "زائر");
        }
        else
        {
            IsOrg = false;
            IsAdmin = false;
            IsCitizen = false;
            UserInitial = "م";
            UserLabel = "زائر";
        }
    }

    private void ToggleOffline()
    {
        IsOffline = !IsOffline;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SetCurrentPage();
        SetUserContext();
        InvokeAsync(StateHasChanged);
    }

    private void SetCurrentPage()
    {
        var rawPath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0];
        var path = rawPath.Trim('/').ToLowerInvariant();
        IsEntryPage = string.IsNullOrWhiteSpace(path)
            || path == "admin/login"
            || path == "org/login"
            || path == "org/register"
            || path == "citizen/login"
            || path == "citizen/register";

        CurrentTitle = path switch
        {
            "" => "نقطة - بوابة الدخول",
            "admin/login" => "نقطة - دخول مسؤول النظام",
            "org/login" => "نقطة - دخول مؤسسة",
            "org/register" => "نقطة - إنشاء مؤسسة",
            "citizen/login" => "نقطة - دخول مواطن",
            "citizen/register" => "نقطة - إنشاء مواطن",
            "org/dashboard" => "نقطة - مسار المؤسسة",
            "admin/dashboard" => "نقطة - مسؤول البرنامج",
            "citizen/profile" => "نقطة - ملف المواطن",
            "aid-distribution" => "نقطة - الجدولة والتوزيع",
            "gap-detector" => "نقطة - كشف الفجوات",
            "analytics" => "نقطة - التحليلات",
            "volunteers" => "نقطة - المتطوعون",
            "settings" => "نقطة - الإعدادات",
            _ => "نقطة - مركز تنسيق الإغاثة"
        };
    }

    private async Task RunClockAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(clockCancellation.Token))
            {
                ClockText = FormatLocalTime();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private static string FormatLocalTime()
    {
        var culture = System.Globalization.CultureInfo.GetCultureInfo("ar");
        return DateTime.Now.ToString("dddd، dd MMMM yyyy، hh:mm:ss tt", culture);
    }

    public void Dispose()
    {
        clockCancellation.Cancel();
        clockCancellation.Dispose();
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
