@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

@if (IsEntryPage)
{
    <main class="entry-main" dir="rtl">@Body</main>
}
else
{
    <div class="app-shell" dir="rtl">
        <aside class="sidebar">
            <a class="brand" href="/" aria-label="نقطة - الصفحة الرئيسية">
                <span class="brand-mark">ن</span>
                <span class="brand-copy"><strong>نقطة</strong><small>مركز تنسيق الإغاثة</small></span>
            </a>

            <div class="sidebar-context"><span></span>منصة موحّدة للقرار</div>

            <nav class="nav-links" aria-label="التنقل الرئيسي">
                @if (IsAdmin)
                {
                    <NavLink class="nav-link" href="admin/dashboard"><span class="nav-icon">إ</span><span>لوحة الإدارة</span></NavLink>
                }
                @if (IsOrg)
                {
                    <NavLink class="nav-link" href="org/dashboard"><span class="nav-icon">م</span><span>لوحة المؤسسة</span></NavLink>
                }
                @if (IsCitizen)
                {
                    <NavLink class="nav-link" href="citizen/profile"><span class="nav-icon">و</span><span>ملف المواطن</span></NavLink>
                }
                @if (IsAdmin || IsOrg)
                {
                    <NavLink class="nav-link" href="aid-distribution"><span class="nav-icon">ج</span><span>الجدولة والتوزيع</span></NavLink>
                    <NavLink class="nav-link" href="gap-detector"><span class="nav-icon">ف</span><span>فجوات التغطية</span></NavLink>
                    <NavLink class="nav-link" href="volunteers"><span class="nav-icon">ط</span><span>المتطوعون</span></NavLink>
                }
                @if (IsAuthenticated)
                {
                    <NavLink class="nav-link" href="analytics"><span class="nav-icon">ت</span><span>تحليلات التوزيع</span></NavLink>
                }
                @if (IsAdmin)
                {
                    <NavLink class="nav-link" href="settings"><span class="nav-icon">ض</span><span>الإعدادات</span></NavLink>
                }
            </nav>

            <div class="sidebar-user">
                <span class="user-avatar">@UserInitial</span>
                <span class="user-copy"><strong>@UserLabel</strong><small>@RoleLabel</small></span>
                @if (IsAuthenticated)
                {
                    <form method="post" action="/auth/logout/form">
                        <AntiforgeryToken />
                        <button class="logout-button" type="submit" title="تسجيل الخروج" aria-label="تسجيل الخروج">خروج</button>
                    </form>
                }
            </div>
        </aside>

        <main class="main-panel">
            <header class="topbar">
                <div class="topbar-title"><span>مركز العمليات</span><h1>@CurrentTitle</h1></div>
                <div class="topbar-meta"><span class="live-status"><i></i> جلسة نشطة</span><time>@DateText</time></div>
            </header>
            <article class="content">@Body</article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>حدث خطأ غير متوقع. <a href="." class="reload">إعادة التحميل</a><span class="dismiss">×</span></div>

@code {
    private bool IsEntryPage { get; set; } = true;
    private string CurrentTitle { get; set; } = "بوابة الدخول";
    private bool IsOrg { get; set; }
    private bool IsCitizen { get; set; }
    private bool IsAdmin { get; set; }
    private bool IsAuthenticated => IsOrg || IsCitizen || IsAdmin;
    private string UserInitial { get; set; } = "ز";
    private string UserLabel { get; set; } = "زائر";
    private string RoleLabel { get; set; } = "بوابة عامة";
    private string DateText => DateTime.Now.ToString("dddd، dd MMMM", System.Globalization.CultureInfo.GetCultureInfo("ar"));

    protected override async Task OnInitializedAsync()
    {
        SetCurrentPage();
        await SetUserContextAsync();
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private async Task SetUserContextAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var actorType = user.FindFirst("actor_type")?.Value;
        IsOrg = actorType == "Organization";
        IsAdmin = actorType == "Admin";
        IsCitizen = actorType == "Individual";
        var name = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
        UserInitial = name.Length > 0 ? name[..1] : "ز";
        UserLabel = string.IsNullOrWhiteSpace(name) ? "زائر" : name;
        RoleLabel = IsAdmin ? "مسؤول النظام" : IsOrg ? "حساب مؤسسة" : IsCitizen ? "حساب مواطن" : "بوابة عامة";
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SetCurrentPage();
        await SetUserContextAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void SetCurrentPage()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/').ToLowerInvariant();
        IsEntryPage = string.IsNullOrWhiteSpace(path) || path is "admin/login" or "org/login" or "org/register" or "citizen/login" or "citizen/register";
        CurrentTitle = path switch
        {
            "" => "بوابة الدخول",
            "admin/dashboard" => "لوحة الإدارة",
            "org/dashboard" => "لوحة المؤسسة",
            "citizen/profile" => "ملف المواطن",
            "aid-distribution" => "الجدولة والتوزيع",
            "gap-detector" => "فجوات التغطية",
            "analytics" => "التحليلات",
            "volunteers" => "المتطوعون",
            "settings" => "الإعدادات",
            _ => "مركز تنسيق الإغاثة"
        };
    }

    public void Dispose() => Navigation.LocationChanged -= HandleLocationChanged;
}
