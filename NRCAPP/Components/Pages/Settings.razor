@page "/settings"

<PageTitle>نقطة - الإعدادات</PageTitle>

<section class="feature-page settings-page" dir="rtl">
    <div class="settings-panel">
        <h2>إعدادات النموذج التجريبي</h2>
        <label><input type="checkbox" checked /> تفعيل وضع عدم الاتصال</label>
        <label><input type="checkbox" checked /> إظهار طبقة الفجوات الحرجة</label>
        <label><input type="checkbox" /> محاكاة تأخير المزامنة</label>
    </div>

    <div class="feature-phone">
        <div class="phone-header">نقطة - الإعدادات</div>
        <div class="feature-card primary">
            <h2>قنوات المزامنة</h2>
            <p>رسائل SMS، مكالمة صوتية، ورفع تلقائي عند عودة الاتصال.</p>
            <button type="button">حفظ الإعدادات</button>
        </div>
    </div>

    <aside class="feature-aside">
        <h2>ملاحظة العرض</h2>
        <p>كل البيانات في هذا النموذج وهمية ومخصصة للعرض الأكاديمي فقط.</p>
    </aside>
</section>
