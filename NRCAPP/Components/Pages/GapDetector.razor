@page "/gap-detector"

<PageTitle>نقطة - كشف الفجوات</PageTitle>

<section class="feature-page gap-page" dir="rtl">
    <div class="feature-map gap-map">
        <div class="territory">
            <span>جباليا</span>
            <span>غزة</span>
            <span>خان يونس</span>
        </div>
        <div class="cash-legend">
            <span><i class="blue"></i>مخدومة جيداً</span>
            <span><i class="gold"></i>مخدومة حديثاً</span>
            <span><i class="red"></i>فجوات حرجة</span>
        </div>
    </div>

    <div class="feature-phone">
        <div class="phone-header">نقطة - خريطة فجوات نقدية</div>
        <div class="feature-card primary">
            <h2>فجوات نقدية شمال غزة</h2>
            <div class="gap-stack">
                <p><b>غزة</b><span>فجوة متوسطة</span></p>
                <p><b>دير البلح</b><span>أولوية عالية</span></p>
                <p><b>رفح</b><span>موقع يحتاج تحقق</span></p>
            </div>
        </div>
        <button class="wide-action" type="button">طلب كشف تعارض نقدي</button>
    </div>

    <aside class="feature-aside">
        <h2>حالة التحقق الحالية</h2>
        <p>لا يوجد تكرار نقدي حالياً في الرمال، لكن خان يونس تحتاج إعادة توجيه للموارد خلال الجولة التالية.</p>
        <div class="signal-bars"><span></span><span></span><span></span></div>
    </aside>
</section>
