@page "/"
@inject ReliefAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>نقطة - بوابة الدخول</PageTitle>

<section class="gateway-page" dir="rtl">
    <div class="gateway-hero">
        <span class="eyebrow">Gaza Relief Coordination Hub</span>
        <h2>دخول بسيط للمؤسسة والمواطن من مكان واحد</h2>
        <p>
            المؤسسة تدخل برقم الترخيص والرمز لإضافة خطط التوزيع وفحص التكرار. المواطن يدخل برقم الهوية ليرى المساعدات القريبة من قطاعه ويسجل حضوره بسهولة.
        </p>
    </div>

    <div class="gateway-tabs" role="tablist" aria-label="نوع المستخدم">
        <button type="button" class="@(ActiveTab == "org" ? "active" : "")" @onclick='() => ActiveTab = "org"'>مؤسسة</button>
        <button type="button" class="@(ActiveTab == "citizen" ? "active" : "")" @onclick='() => ActiveTab = "citizen"'>مواطن</button>
    </div>

    <section class="gateway-grid">
        @if (ActiveTab == "org")
        {
            <article class="form-panel gateway-card">
                <div class="panel-title">
                    <span>م</span>
                    <div>
                        <h3>دخول المؤسسة</h3>
                        <p>بيانات تجربة جاهزة: UNRWA-GZA-001 والرمز 123456.</p>
                    </div>
                </div>

                <label>رقم ترخيص المؤسسة</label>
                <input @bind="LicenseId" placeholder="UNRWA-GZA-001" />

                <label>رمز الدخول</label>
                <input @bind="Passcode" type="password" placeholder="123456" />

                <button type="button" @onclick="LoginOrganization">دخول إلى لوحة المؤسسة</button>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="result-box @(IsSuccess ? "success" : "warning")">@Message</div>
                }
            </article>
        }
        else
        {
            <article class="form-panel gateway-card">
                <div class="panel-title">
                    <span>و</span>
                    <div>
                        <h3>دخول المواطن</h3>
                        <p>بيانات تجربة جاهزة: 900112233 والقطاع الرمال.</p>
                    </div>
                </div>

                <label>رقم الهوية الوطنية</label>
                <input @bind="NationalId" placeholder="900112233" />

                <label>القطاع الحالي</label>
                <select @bind="CurrentSector">
                    @foreach (var sector in Sectors)
                    {
                        <option value="@sector">@sector</option>
                    }
                </select>

                <button type="button" @onclick="LoginCitizen">فتح ملف المواطن</button>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="result-box @(IsSuccess ? "success" : "warning")">@Message</div>
                }
            </article>
        }

        <aside class="journey-panel">
            <h3>ليش أحياناً الخطة لا تُعتمد؟</h3>
            <div class="journey-step"><b>1</b><span>إذا كان نفس القطاع ونفس نوع المساعدة موجودين خلال 48 ساعة، النظام يمنع التكرار.</span></div>
            <div class="journey-step"><b>2</b><span>الخطة لا تختفي؛ تُحفظ كتحذير في قاعدة البيانات مع رقمها.</span></div>
            <div class="journey-step"><b>3</b><span>لتعتمد الخطة غيّر التاريخ، أو القطاع، أو نوع المساعدة.</span></div>
            <div class="journey-step"><b>4</b><span>طلبات التسجيل وتأكيد الحضور تحفظ في نفس قاعدة البيانات.</span></div>
        </aside>
    </section>
</section>

@code {
    private string ActiveTab { get; set; } = "org";
    private string LicenseId { get; set; } = "UNRWA-GZA-001";
    private string Passcode { get; set; } = "123456";
    private string NationalId { get; set; } = "900112233";
    private string CurrentSector { get; set; } = "الرمال";
    private string? Message { get; set; }
    private bool IsSuccess { get; set; }
    private string[] Sectors { get; } = ["الرمال", "جباليا", "خان يونس", "دير البلح", "رفح"];

    private async Task LoginOrganization()
    {
        var response = await AuthService.LoginOrganizationAsync(new OrganizationLoginRequest(LicenseId, Passcode));
        IsSuccess = response.IsAuthenticated;

        if (!response.IsAuthenticated || response.ActorId is null)
        {
            Message = response.Message;
            return;
        }

        Navigation.NavigateTo($"/org/dashboard?orgId={response.ActorId}");
    }

    private async Task LoginCitizen()
    {
        var response = await AuthService.LoginIndividualAsync(new IndividualLoginRequest(NationalId));
        IsSuccess = response.IsAuthenticated;

        if (!response.IsAuthenticated)
        {
            Message = response.Message;
            return;
        }

        Navigation.NavigateTo($"/citizen/profile?nationalId={Uri.EscapeDataString(NationalId.Trim())}&sector={Uri.EscapeDataString(CurrentSector)}");
    }
}
