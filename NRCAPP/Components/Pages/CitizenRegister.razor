@page "/citizen/register"
@layout MainLayout
@inject NavigationManager Navigation

<PageTitle>نقطة - إنشاء مواطن</PageTitle>

<section class="entry-gateway" dir="rtl">
    <div class="entry-brand">
        <span>ن</span>
        <div>
            <strong>نقطة</strong>
            <small>مركز تنسيق الإغاثة</small>
        </div>
    </div>

    <section class="entry-panel">
        <div class="panel-title">
            <h1>إنشاء حساب مواطن</h1>
            <p>بعد الحفظ يستطيع المواطن الدخول برقم الهوية ومتابعة التوزيعات المتاحة.</p>
        </div>

        <div class="gateway-card">
            <form method="post" action="/auth/citizen/register">
                <label for="citizen-name">الاسم الكامل</label>
                <input id="citizen-name" name="fullName" placeholder="اسم المواطن" required />

                <label for="citizen-national">رقم الهوية الوطنية</label>
                <input id="citizen-national" name="nationalId" placeholder="رقم الهوية" required />

                <label for="citizen-family">عدد أفراد الأسرة</label>
                <input id="citizen-family" name="familyMembers" type="number" min="1" value="1" required />

                <label for="citizen-phone">رقم الهاتف</label>
                <input id="citizen-phone" name="phone" placeholder="رقم الهاتف" required />

                <label for="citizen-sector">القطاع الحالي</label>
                <select id="citizen-sector" name="sector">
                    <option value="الرمال">الرمال</option>
                    <option value="جباليا">جباليا</option>
                    <option value="خان يونس">خان يونس</option>
                    <option value="دير البلح">دير البلح</option>
                    <option value="رفح">رفح</option>
                </select>

                <button type="submit">إنشاء حساب المواطن والدخول</button>
            </form>

            @if (Navigation.Uri.Contains("error=empty"))
            {
                <div class="result-box warning">يرجى تعبئة كل البيانات.</div>
            }
            else if (Navigation.Uri.Contains("error="))
            {
                <div class="result-box warning">فشل إنشاء الحساب. قد يكون رقم الهوية مسجلاً مسبقاً.</div>
            }

            <p class="auth-switch">
                لديك حساب بالفعل؟
                <a href="/citizen/login">دخول المواطن</a>
            </p>
            <p class="auth-switch"><a href="/">العودة إلى بوابة الدخول</a></p>
        </div>
    </section>
</section>
