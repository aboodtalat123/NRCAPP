@page "/citizen/register"
@layout MainLayout
@inject NavigationManager Navigation

<PageTitle>نقطة - تسجيل مواطن</PageTitle>
<section class="entry-gateway auth-entry" dir="rtl"><div class="entry-brand"><span>ن</span><div><strong>نقطة</strong><small>مركز تنسيق الإغاثة</small></div></div><section class="entry-panel auth-panel"><div class="panel-title"><span class="eyebrow">مسار المواطن</span><h1>أنشئ ملفك في نقطة</h1><p>بيانات بسيطة تساعدك على رؤية التوزيعات المتاحة في منطقتك وتأكيد استلامك.</p></div><div class="gateway-card"><form method="post" action="/auth/citizen/register"><label for="citizen-name">الاسم الكامل</label><input id="citizen-name" name="fullName" placeholder="الاسم كما في الهوية" required /><label for="citizen-national">رقم الهوية الوطنية</label><input id="citizen-national" name="nationalId" placeholder="أدخل رقم الهوية" required /><label for="citizen-family">عدد أفراد الأسرة</label><input id="citizen-family" name="familyMembers" type="number" min="1" value="1" required /><label for="citizen-phone">رقم الهاتف</label><input id="citizen-phone" name="phone" placeholder="رقم هاتف للتواصل" required /><label for="citizen-sector">المنطقة الحالية</label><select id="citizen-sector" name="sector"><option value="الرمال">الرمال</option><option value="جباليا">جباليا</option><option value="خان يونس">خان يونس</option><option value="دير البلح">دير البلح</option><option value="رفح">رفح</option></select><button type="submit">إنشاء الملف والدخول <span>←</span></button></form>@if (Navigation.Uri.Contains("error=")) { <div class="result-box warning">تعذر إنشاء الحساب. تأكد من تعبئة البيانات وأن رقم الهوية غير مسجل مسبقاً.</div> }<p class="auth-switch">لديك حساب بالفعل؟ <a href="/citizen/login">دخول المواطن</a></p><p class="auth-switch"><a href="/">العودة إلى بوابة الدخول</a></p></div></section></section>
