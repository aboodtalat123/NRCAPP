@page "/admin/dashboard"
@inject AdminAuthService AdminAuth
@inject NavigationManager Navigation
@inject ReliefDbContext Db
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>نقطة - لوحة الإدارة</PageTitle>

<section class="admin-shell" dir="rtl">
    <aside class="admin-sidebar">
        <div class="admin-brand">
            <span>ن</span>
            <div>
                <strong>نقطة</strong>
                <small>مسؤول النظام</small>
            </div>
            <b>ADMIN</b>
        </div>

        <nav class="admin-nav" aria-label="تنقل لوحة الإدارة">
            <a class="active" href="/admin/dashboard">لوحة الإدارة</a>
            <a href="/admin/dashboard#pending">بانتظار الاعتماد</a>
            <a href="/admin/dashboard#organizations">المؤسسات</a>
            <a href="/admin/dashboard#audit">سجل النظام</a>
            <a href="/analytics">تقارير</a>
            <button type="button" @onclick="Logout">تسجيل الخروج</button>
        </nav>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <span class="eyebrow">نظرة تشغيلية موحدة</span>
                <h1>لوحة الإدارة</h1>
                <p>متابعة المؤسسات، خطط التوزيع، التعارضات التي تم منعها، وحالة المزامنة الميدانية.</p>
            </div>
            <div class="admin-profile">
                <span>@AdminName</span>
                <small>SuperAdmin</small>
            </div>
        </header>

        <section class="admin-summary-grid">
            <article>
                <span>مؤسسات نشطة</span>
                <strong>@ActiveOrganizationsCount</strong>
            </article>
            <article>
                <span>بانتظار الاعتماد</span>
                <strong class="warning">@PendingApprovalCount</strong>
            </article>
            <article>
                <span>تعارضات مُنعت</span>
                <strong class="danger">@ConflictsPrevented</strong>
            </article>
            <article>
                <span>مزامنة معلقة</span>
                <strong class="warning">@PendingSyncCount</strong>
            </article>
        </section>

        <section class="admin-content-grid">
            @if (PendingApprovalCount > 0)
            {
                <article class="admin-panel" id="pending">
                    <div class="admin-panel-title">
                        <div>
                            <h2>مؤسسات بانتظار الاعتماد</h2>
                            <p>قم باعتماد أو رض المؤسسات الجديدة المسجلة.</p>
                        </div>
                    </div>

                    <div class="admin-table">
                        <div class="admin-table-head">
                            <span>المؤسسة</span>
                            <span>رقم الترخيص</span>
                            <span>الشخص المخول</span>
                            <span>تاريخ التسجيل</span>
                            <span>إجراءات</span>
                        </div>
                        @foreach (var org in PendingOrganizations)
                        {
                            <div class="admin-table-row">
                                <span>@org.NgoName</span>
                                <span>@org.LicenseId</span>
                                <span>@org.AuthorizedPerson</span>
                                <span>@org.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                                <span class="actions-cell">
                                    <button type="button" class="admin-row-button approve" @onclick="() => ApproveOrg(org.Id)">اعتماد</button>
                                    <button type="button" class="admin-row-button reject" @onclick="() => ShowRejectDialog(org.Id, org.NgoName)">رفض</button>
                                </span>
                            </div>
                            @if (org.RejectionReason is not null)
                            {
                                <div class="admin-table-row rejection-reason">
                                    <span colspan="5">سبب الرفض: @org.RejectionReason</span>
                                </div>
                            }
                        }
                    </div>
                </article>
            }

            @if (ShowRejectForm)
            {
                <div class="modal-overlay">
                    <div class="modal-box">
                        <h3>رفض المؤسسة: @RejectOrgName</h3>
                        <label for="reject-reason">سبب الرفض:</label>
                        <textarea id="reject-reason" @bind="RejectReason" rows="3" placeholder="أدخل سبب الرفض"></textarea>
                        <div class="modal-actions">
                            <button type="button" class="admin-row-button approve" @onclick="ConfirmReject">تأكيد الرفض</button>
                            <button type="button" class="admin-row-button" @onclick="CancelReject">إلغاء</button>
                        </div>
                        @if (!string.IsNullOrEmpty(RejectError))
                        {
                            <div class="result-box warning">@RejectError</div>
                        }
                    </div>
                </div>
            }

            <article class="admin-panel" id="organizations">
                <div class="admin-panel-title">
                    <div>
                        <h2>المؤسسات</h2>
                        <p>جميع المؤسسات المسجلة في قاعدة البيانات.</p>
                    </div>
                </div>

                <div class="admin-table org-admin-table">
                    <div class="admin-table-head">
                        <span>المؤسسة</span>
                        <span>رقم الترخيص</span>
                        <span>عدد الخطط</span>
                        <span>الحالة</span>
                        <span>إجراءات</span>
                    </div>
                    @foreach (var organization in Organizations)
                    {
                        <div class="admin-table-row">
                            <span>@organization.Name</span>
                            <span>@organization.LicenseId</span>
                            <span>@organization.PlansCount</span>
                            <span class="pill @(organization.IsVerified ? "pill-active" : "pill-conflict")">
                                @(organization.IsVerified ? "فعالة" : "معلقة")
                            </span>
                            <button type="button" class="admin-row-button" @onclick="() => ToggleOrganizationAsync(organization.Id)">
                                @(organization.IsVerified ? "تعليق" : "تفعيل")
                            </button>
                        </div>
                    }
                    @if (Organizations.Count == 0)
                    {
                        <p class="empty-state">لا توجد مؤسسات مسجلة حتى الآن.</p>
                    }
                </div>
            </article>

            <article class="admin-panel" id="audit">
                <div class="admin-panel-title">
                    <div>
                        <h2>سجل النظام</h2>
                        <p>آخر 50 حدث في النظام.</p>
                    </div>
                </div>

                <div class="admin-table">
                    <div class="admin-table-head">
                        <span>التاريخ</span>
                        <span>الإجراء</span>
                        <span>التفاصيل</span>
                    </div>
                    @foreach (var log in AuditLogs)
                    {
                        <div class="admin-table-row">
                            <span>@log.Timestamp.ToLocalTime().ToString("MM/dd HH:mm")</span>
                            <span>@log.Action</span>
                            <span>@log.Details</span>
                        </div>
                    }
                    @if (AuditLogs.Count == 0)
                    {
                        <p class="empty-state">لا توجد أحداث مسجلة بعد.</p>
                    }
                </div>
            </article>
        </section>
    </main>
</section>

@code {
    private int ActiveOrganizationsCount { get; set; }
    private int PlansThisMonthCount { get; set; }
    private int ConflictsPrevented { get; set; }
    private int PendingSyncCount { get; set; }
    private int PendingApprovalCount { get; set; }
    private string AdminName { get; set; } = "مسؤول النظام";
    private List<OrganizationView> Organizations { get; set; } = [];
    private List<PendingOrganizationView> PendingOrganizations { get; set; } = [];
    private List<Api.AuditLogItem> AuditLogs { get; set; } = [];
    private bool ShowRejectForm { get; set; }
    private int RejectOrgId { get; set; }
    private string RejectOrgName { get; set; } = "";
    private string RejectReason { get; set; } = "";
    private string RejectError { get; set; } = "";

    private sealed record OrganizationView(int Id, string Name, string LicenseId, int PlansCount, bool IsVerified);
    private sealed record PendingOrganizationView(int Id, string LicenseId, string NgoName, string AuthorizedPerson, DateTimeOffset CreatedAt, string? RejectionReason);

    protected override async Task OnInitializedAsync()
    {
        if (!AdminAuth.IsLoggedIn())
        {
            Navigation.NavigateTo("/admin/login");
            return;
        }

        var user = HttpContextAccessor.HttpContext?.User;
        AdminName = user?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "مسؤول النظام";

        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        var now = DateTimeOffset.UtcNow;
        var monthStart = new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero);
        var nextMonth = monthStart.AddMonths(1);

        ActiveOrganizationsCount = await Db.Organizations.AsNoTracking().CountAsync(x => x.IsVerified);
        ConflictsPrevented = await Db.DistributionPlans.AsNoTracking().CountAsync(x => x.Status == DistributionPlanStatus.Warning);
        PendingSyncCount = await Db.SyncQueueItems.AsNoTracking().CountAsync(x => x.SyncStatus == SyncStatus.Pending);

        PendingApprovalCount = await Db.Organizations.AsNoTracking().CountAsync(x => !x.IsVerified);

        Organizations = await Db.Organizations
            .AsNoTracking()
            .Include(x => x.DistributionPlans)
            .OrderBy(x => x.NgoName)
            .Select(x => new OrganizationView(x.Id, x.NgoName, x.LicenseId, x.DistributionPlans.Count, x.IsVerified))
            .ToListAsync();

        PendingOrganizations = await Db.Organizations
            .AsNoTracking()
            .Where(x => !x.IsVerified)
            .OrderByDescending(x => x.CreatedAt)
            .Select(x => new PendingOrganizationView(x.Id, x.LicenseId, x.NgoName, x.AuthorizedPerson, x.CreatedAt, x.RejectionReason))
            .ToListAsync();

        AuditLogs = await Db.AuditLogs
            .AsNoTracking()
            .OrderByDescending(x => x.Timestamp)
            .Take(50)
            .Select(x => new Api.AuditLogItem(x.Id, x.ActorType, x.Action, x.EntityName, x.EntityId, x.Details, x.Timestamp))
            .ToListAsync();
    }

    private async Task ToggleOrganizationAsync(int id)
    {
        var organization = await Db.Organizations.SingleOrDefaultAsync(x => x.Id == id);
        if (organization is null) return;

        organization.IsVerified = !organization.IsVerified;
        if (!organization.IsVerified)
        {
            organization.RejectionReason = "تم التعليق بواسطة المسؤول";
        }
        await Db.SaveChangesAsync();

        Db.AuditLogs.Add(new AuditLog
        {
            ActorType = "Admin",
            Action = organization.IsVerified ? "تفعيل مؤسسة" : "تعليق مؤسسة",
            EntityName = nameof(Organization),
            EntityId = organization.Id,
            Details = $"{organization.NgoName} ({organization.LicenseId})"
        });
        await Db.SaveChangesAsync();

        await LoadDashboardAsync();
    }

    private async Task ApproveOrg(int orgId)
    {
        var (success, msg) = await AdminAuth.ApproveOrganizationAsync(orgId);
        if (success) await LoadDashboardAsync();
    }

    private void ShowRejectDialog(int orgId, string orgName)
    {
        RejectOrgId = orgId;
        RejectOrgName = orgName;
        RejectReason = "";
        RejectError = "";
        ShowRejectForm = true;
    }

    private void CancelReject()
    {
        ShowRejectForm = false;
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(RejectReason))
        {
            RejectError = "الرجاء إدخال سبب الرفض.";
            return;
        }

        var (success, msg) = await AdminAuth.RejectOrganizationAsync(RejectOrgId, RejectReason);
        if (success)
        {
            ShowRejectForm = false;
            await LoadDashboardAsync();
        }
        else
        {
            RejectError = msg;
        }
    }

    private async Task Logout()
    {
        await AdminAuth.LogoutAsync();
        Navigation.NavigateTo("/admin/login", forceLoad: true);
    }
}
