@page "/admin/dashboard"
@inject AdminAuthService AdminAuth
@inject NavigationManager Navigation
@inject ReliefDbContext Db

<PageTitle>نقطة - لوحة الإدارة</PageTitle>

<section class="admin-shell" dir="rtl">
    <aside class="admin-sidebar">
        <div class="admin-brand">
            <span>ن</span>
            <div>
                <strong>نقطة</strong>
                <small>مسؤول النظام</small>
            </div>
            <b>ADMIN</b>
        </div>

        <nav class="admin-nav" aria-label="تنقل لوحة الإدارة">
            <a class="active" href="/admin/dashboard">لوحة الإدارة</a>
            <a href="/admin/dashboard#organizations">المؤسسات</a>
            <a href="/admin/dashboard#plans">جميع الخطط</a>
            <a href="/admin/dashboard#conflicts">التعارضات <span>@ConflictsPrevented</span></a>
            <a href="/admin/dashboard#sync">المزامنة <span>@PendingSyncCount</span></a>
            <a href="/analytics">تقارير</a>
            <button type="button" data-action="logout-admin" onclick="window.nrcappForms?.handleEntryAction('logout-admin')">تسجيل الخروج</button>
        </nav>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <span class="eyebrow">نظرة تشغيلية موحدة</span>
                <h1>لوحة الإدارة</h1>
                <p>متابعة المؤسسات، خطط التوزيع، التعارضات التي تم منعها، وحالة المزامنة الميدانية.</p>
            </div>
            <div class="admin-profile">
                <span>@(AdminAuth.Current?.FullName ?? "مسؤول النظام")</span>
                <small>@(AdminAuth.Current?.Role ?? "SuperAdmin")</small>
            </div>
        </header>

        <section class="admin-summary-grid">
            <article>
                <span>مؤسسات نشطة</span>
                <strong>@ActiveOrganizationsCount</strong>
            </article>
            <article>
                <span>خطط هذا الشهر</span>
                <strong>@PlansThisMonthCount</strong>
            </article>
            <article>
                <span>تعارضات مُنعت</span>
                <strong class="danger">@ConflictsPrevented</strong>
            </article>
            <article>
                <span>مزامنة معلقة</span>
                <strong class="warning">@PendingSyncCount</strong>
            </article>
        </section>

        <section class="admin-content-grid">
            <article class="admin-panel" id="organizations">
                <div class="admin-panel-title">
                    <div>
                        <h2>المؤسسات</h2>
                        <p>تفعيل أو تعليق المؤسسات المسجلة في قاعدة البيانات.</p>
                    </div>
                </div>

                <div class="admin-table org-admin-table">
                    <div class="admin-table-head">
                        <span>المؤسسة</span>
                        <span>رقم الترخيص</span>
                        <span>عدد الخطط</span>
                        <span>الحالة</span>
                        <span>إجراءات</span>
                    </div>
                    @foreach (var organization in Organizations)
                    {
                        <div class="admin-table-row">
                            <span>@organization.Name</span>
                            <span>@organization.LicenseId</span>
                            <span>@organization.PlansCount</span>
                            <span class="pill @(organization.IsVerified ? "pill-active" : "pill-conflict")">
                                @(organization.IsVerified ? "فعالة" : "معلقة")
                            </span>
                            <button type="button" class="admin-row-button" @onclick="() => ToggleOrganizationAsync(organization.Id)">
                                @(organization.IsVerified ? "تعليق" : "تفعيل")
                            </button>
                        </div>
                    }
                    @if (Organizations.Count == 0)
                    {
                        <p class="empty-state">لا توجد مؤسسات مسجلة حتى الآن.</p>
                    }
                </div>
            </article>

            <article class="admin-panel" id="plans">
                <div class="admin-panel-title">
                    <div>
                        <h2>أحدث الخطط</h2>
                        <p>آخر خطط التوزيع عبر القطاعات والمؤسسات.</p>
                    </div>
                </div>

                <div class="admin-table plan-admin-table">
                    <div class="admin-table-head">
                        <span>المؤسسة</span>
                        <span>القطاع</span>
                        <span>المساعدة</span>
                        <span>الموعد</span>
                        <span>الحالة</span>
                    </div>
                    @foreach (var plan in RecentPlans)
                    {
                        <div class="admin-table-row">
                            <span>@plan.OrganizationName</span>
                            <span>@plan.Sector</span>
                            <span>@ToArabicAidType(plan.AidType)</span>
                            <span>@plan.ScheduledDate.ToLocalTime().ToString("MM/dd HH:mm")</span>
                            <span class="pill @ToStatusClass(plan.Status)">@ToArabicStatus(plan.Status)</span>
                        </div>
                    }
                    @if (RecentPlans.Count == 0)
                    {
                        <p class="empty-state">لا توجد خطط توزيع بعد.</p>
                    }
                </div>
            </article>
        </section>
    </main>
</section>

@code {
    private sealed record OrganizationView(int Id, string Name, string LicenseId, int PlansCount, bool IsVerified);
    private sealed record RecentPlanView(string OrganizationName, string Sector, AidKind AidType, DateTimeOffset ScheduledDate, DistributionPlanStatus Status);

    private int ActiveOrganizationsCount { get; set; }
    private int PlansThisMonthCount { get; set; }
    private int ConflictsPrevented { get; set; }
    private int PendingSyncCount { get; set; }
    private List<OrganizationView> Organizations { get; set; } = [];
    private List<RecentPlanView> RecentPlans { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        if (!AdminAuth.IsLoggedIn())
        {
            Navigation.NavigateTo("/admin/login");
            return;
        }

        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        var now = DateTimeOffset.UtcNow;
        var monthStart = new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero);
        var nextMonth = monthStart.AddMonths(1);

        ActiveOrganizationsCount = await Db.Organizations.AsNoTracking().CountAsync(x => x.IsVerified);
        PlansThisMonthCount = await Db.DistributionPlans.AsNoTracking().CountAsync(x => x.ScheduledDate >= monthStart && x.ScheduledDate < nextMonth);
        ConflictsPrevented = await Db.DistributionPlans.AsNoTracking().CountAsync(x => x.Status == DistributionPlanStatus.Warning);
        PendingSyncCount = await Db.SyncQueueItems.AsNoTracking().CountAsync(x => x.SyncStatus == SyncStatus.Pending);

        Organizations = await Db.Organizations
            .AsNoTracking()
            .Include(x => x.DistributionPlans)
            .OrderBy(x => x.NgoName)
            .Select(x => new OrganizationView(x.Id, x.NgoName, x.LicenseId, x.DistributionPlans.Count, x.IsVerified))
            .ToListAsync();

        RecentPlans = await Db.DistributionPlans
            .AsNoTracking()
            .Include(x => x.Organization)
            .OrderByDescending(x => x.CreatedAt)
            .Take(12)
            .Select(x => new RecentPlanView(
                x.Organization == null ? "غير معروف" : x.Organization.NgoName,
                x.TargetSector,
                x.AidType,
                x.ScheduledDate,
                x.Status))
            .ToListAsync();
    }

    private async Task ToggleOrganizationAsync(int id)
    {
        var organization = await Db.Organizations.SingleOrDefaultAsync(x => x.Id == id);
        if (organization is null)
        {
            return;
        }

        organization.IsVerified = !organization.IsVerified;
        await Db.SaveChangesAsync();
        await LoadDashboardAsync();
    }

    private static string ToArabicAidType(AidKind aidType) => aidType switch
    {
        AidKind.FoodBasket => "سلة غذائية",
        AidKind.SafeDrinkingWater => "مياه آمنة",
        AidKind.MedicalSupplies => "مستلزمات طبية",
        AidKind.ShelterKits => "حقائب إيواء",
        _ => aidType.ToString()
    };

    private static string ToArabicStatus(DistributionPlanStatus status) => status switch
    {
        DistributionPlanStatus.Authorized => "معتمدة",
        DistributionPlanStatus.Warning => "تعارض",
        DistributionPlanStatus.Completed => "مكتملة",
        DistributionPlanStatus.Cancelled => "ملغية",
        _ => "مسودة"
    };

    private static string ToStatusClass(DistributionPlanStatus status) => status switch
    {
        DistributionPlanStatus.Authorized => "pill-active",
        DistributionPlanStatus.Warning => "pill-conflict",
        DistributionPlanStatus.Completed => "pill-done",
        _ => "pill-pending"
    };
}
