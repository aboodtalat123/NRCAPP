@page "/aid-distribution"
@inject ReliefDbContext Db
@inject NavigationManager Navigation

<PageTitle>نقطة - الجدولة والتوزيع</PageTitle>

<section class="feature-page schedule-page" dir="rtl">
    <div class="role-header">
        <div>
            <span class="eyebrow">الجدولة والتوزيع</span>
            <h2>جميع خطط التوزيع</h2>
            <p>عرض وإنشاء خطط التوزيع عبر القطاعات والمؤسسات.</p>
        </div>
    </div>

    <section class="admin-stat-grid">
        <article class="stat-card">
            <span>إجمالي الخطط</span>
            <strong>@AllPlans.Count</strong>
        </article>
        <article class="stat-card">
            <span>معتمدة</span>
            <strong class="success">@AllPlans.Count(p => p.Status == DistributionPlanStatus.Authorized)</strong>
        </article>
        <article class="stat-card">
            <span>تحذير</span>
            <strong class="warning">@AllPlans.Count(p => p.Status == DistributionPlanStatus.Warning)</strong>
        </article>
        <article class="stat-card">
            <span>مكتملة</span>
            <strong>@AllPlans.Count(p => p.Status == DistributionPlanStatus.Completed)</strong>
        </article>
    </section>

    <div class="filter-bar">
        <select @bind="FilterSector">
            <option value="">كل القطاعات</option>
            @foreach (var s in Sectors)
            {
                <option value="@s">@s</option>
            }
        </select>
        <select @bind="FilterStatus">
            <option value="">كل الحالات</option>
            <option value="Authorized">معتمدة</option>
            <option value="Warning">تحذير</option>
            <option value="Completed">مكتملة</option>
            <option value="Cancelled">ملغية</option>
        </select>
    </div>

    <div class="plans-table">
        <div class="table-head">
            <span>المؤسسة</span>
            <span>القطاع</span>
            <span>المساعدة</span>
            <span>الكمية</span>
            <span>السعة</span>
            <span>التاريخ</span>
            <span>الحالة</span>
        </div>
        @foreach (var plan in FilteredPlans)
        {
            <div class="table-row">
                <span>@plan.OrgName</span>
                <span>@plan.TargetSector</span>
                <span>@ToArabicAidType(plan.AidType)</span>
                <span>@plan.Quantity</span>
                <span>@plan.MaxCapacity</span>
                <span>@plan.ScheduledDate.ToLocalTime().ToString("MM/dd HH:mm")</span>
                <span class="pill @ToStatusClass(plan.Status)">@ToArabicStatus(plan.Status)</span>
            </div>
        }
        @if (FilteredPlans.Count == 0)
        {
            <p class="empty-state">لا توجد خطط توزيع بعد.</p>
        }
    </div>

    @if (FilteredPlans.Count > 0)
    {
        <p class="table-count">إجمالي: @FilteredPlans.Count خطة</p>
    }
</section>

@code {
    private sealed record PlanView(string OrgName, AidKind AidType, string TargetSector, int Quantity, int MaxCapacity, DateTimeOffset ScheduledDate, DistributionPlanStatus Status);

    private List<PlanView> AllPlans { get; set; } = [];
    private string FilterSector { get; set; } = "";
    private string FilterStatus { get; set; } = "";
    private string[] Sectors { get; } = ["الرمال", "جباليا", "خان يونس", "دير البلح", "رفح"];

    private List<PlanView> FilteredPlans
    {
        get
        {
            var q = AllPlans.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(FilterSector))
                q = q.Where(p => p.TargetSector == FilterSector);
            if (!string.IsNullOrWhiteSpace(FilterStatus) && Enum.TryParse<DistributionPlanStatus>(FilterStatus, out var status))
                q = q.Where(p => p.Status == status);
            return q.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPlans();
    }

    private async Task LoadPlans()
    {
        AllPlans = await Db.DistributionPlans
            .AsNoTracking()
            .Include(x => x.Organization)
            .OrderByDescending(x => x.ScheduledDate)
            .Select(x => new PlanView(
                x.Organization == null ? "غير معروف" : x.Organization.NgoName,
                x.AidType,
                x.TargetSector,
                x.Quantity,
                x.MaxBeneficiaryCapacity,
                x.ScheduledDate,
                x.Status))
            .ToListAsync();
    }

    private static string ToArabicAidType(AidKind aidType) => aidType switch
    {
        AidKind.FoodBasket => "سلة غذائية",
        AidKind.SafeDrinkingWater => "مياه آمنة",
        AidKind.MedicalSupplies => "مستلزمات طبية",
        AidKind.ShelterKits => "حقائب إيواء",
        _ => aidType.ToString()
    };

    private static string ToArabicStatus(DistributionPlanStatus status) => status switch
    {
        DistributionPlanStatus.Authorized => "معتمدة",
        DistributionPlanStatus.Warning => "تحذير",
        DistributionPlanStatus.Completed => "مكتملة",
        DistributionPlanStatus.Cancelled => "ملغية",
        _ => "مسودة"
    };

    private static string ToStatusClass(DistributionPlanStatus status) => status switch
    {
        DistributionPlanStatus.Authorized => "pill-active",
        DistributionPlanStatus.Warning => "pill-conflict",
        DistributionPlanStatus.Completed => "pill-done",
        _ => "pill-pending"
    };
}
