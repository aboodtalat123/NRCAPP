@page "/aid-distribution"
@inject ConflictDetectionService ConflictDetection
@inject ReliefDbContext Db

<PageTitle>نقطة - الجدولة والتوزيع</PageTitle>

<section class="feature-page schedule-page" dir="rtl">
    <div class="feature-map">
        <span class="feature-pin p1">UNICEF</span>
        <span class="feature-pin p2">UNRWA</span>
        <span class="feature-pin p3">خان يونس</span>
    </div>

    <div class="feature-phone">
        <div class="phone-header">نقطة - الجدولة والمزامنة</div>
        <div class="feature-card primary">
            <h2>تخطيط التوزيع الذكي</h2>
            <p>خطة جديدة لمواءمة الغذاء والمياه حسب الفجوات الحالية ومنع تكرار الخدمة في نفس القطاع.</p>
            <div class="field-row"><span>التاريخ</span><b>27 أيار 2026</b></div>
            <div class="field-row"><span>نوع المساعدة</span><b>مياه + سلة غذائية</b></div>
            <button type="button" @onclick="SubmitDemoPlan">التحقق من التعارض والحفظ</button>
            @if (!string.IsNullOrWhiteSpace(ResultMessage))
            {
                <div class="api-result @(Accepted ? "ok" : "warn")">@ResultMessage</div>
            }
        </div>
        <div class="calendar-grid">
            @foreach (var day in Enumerable.Range(1, 30))
            {
                <span class="@(day is 6 or 12 or 19 ? "has-water" : day is 8 or 13 or 20 ? "has-food" : "")">@day</span>
            }
        </div>
    </div>

    <aside class="feature-aside">
        <h2>كشف تعارض ذكي</h2>
        <p>يتم فحص التوزيع جغرافياً وزمنياً قبل اعتماد الخطة، وتسجيل التحذير إذا ظهرت خطة مشابهة خلال 48 ساعة.</p>
        <ul>
            <li>منع تكرار السلال الغذائية في الرمال</li>
            <li>اقتراح تحويل الموارد إلى مناطق أقل خدمة</li>
            <li>المزامنة جاهزة عند عودة الاتصال</li>
        </ul>
    </aside>
</section>

@code {
    private string? ResultMessage { get; set; }
    private bool Accepted { get; set; }

    private async Task SubmitDemoPlan()
    {
        var organization = await Db.Organizations
            .AsNoTracking()
            .OrderBy(x => x.Id)
            .FirstAsync();

        var result = await ConflictDetection.SubmitPlanAsync(new(
            AidKind.FoodBasket,
            DateTimeOffset.UtcNow.AddHours(24),
            31.501m,
            34.466m,
            "الرمال",
            250,
            organization.Id));

        Accepted = result.Accepted;
        ResultMessage = result.Message;
    }
}
