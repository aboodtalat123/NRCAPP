@page "/aid-distribution"
@inject ConflictDetectionService ConflictDetection
@inject ReliefDbContext Db

<PageTitle>نقطة - الجدولة والتوزيع</PageTitle>

<section class="feature-page schedule-page" dir="rtl">
    <div class="feature-map">
        <span class="feature-pin p1">مؤسسة</span>
        <span class="feature-pin p2">خطة توزيع</span>
        <span class="feature-pin p3">خان يونس</span>
    </div>

    <div class="feature-phone">
        <div class="phone-header">نقطة - الجدولة والمزامنة</div>
        <div class="feature-card primary">
            <h2>تخطيط توزيع ذكي</h2>
            <p>الخطة تُفحص حسب القطاع ونوع المساعدة والتاريخ. إذا كررت نفس المساعدة في نفس القطاع خلال 48 ساعة، تُحفظ كتحذير ولا تُعتمد.</p>
            <div class="field-row"><span>التاريخ</span><b>بعد 7 أيام</b></div>
            <div class="field-row"><span>نوع المساعدة</span><b>سلة غذائية</b></div>
            <button type="button" @onclick="SubmitDemoPlan">حفظ خطة تجريبية للمؤسسة الأولى</button>
            <button type="button" class="ghost-action" @onclick="SubmitConflictPlan">فحص منع التكرار</button>
            @if (!string.IsNullOrWhiteSpace(ResultMessage))
            {
                <div class="api-result @(Accepted ? "ok" : "warn")">@ResultMessage</div>
            }
        </div>
        <div class="calendar-grid">
            @foreach (var day in Enumerable.Range(1, 30))
            {
                <span class="@(day is 6 or 12 or 19 ? "has-water" : day is 8 or 13 or 20 ? "has-food" : "")">@day</span>
            }
        </div>
    </div>

    <aside class="feature-aside">
        <h2>ليش كان يضيف وهلق لا؟</h2>
        <p>إذا كانت هناك خطة بنفس القطاع ونفس نوع المساعدة خلال 48 ساعة، يحفظ النظام المحاولة كتحذير بدل اعتمادها حتى لا يتكرر التوزيع.</p>
        <ul>
            <li>غيّر التاريخ إلى بعد أكثر من 48 ساعة لاعتماد الخطة.</li>
            <li>أو غيّر القطاع إذا كانت الحاجة في مكان آخر.</li>
            <li>أو غيّر نوع المساعدة إذا كانت الخدمة مختلفة.</li>
        </ul>
    </aside>
</section>

@code {
    private string? ResultMessage { get; set; }
    private bool Accepted { get; set; }

    private async Task SubmitDemoPlan()
    {
        await SubmitPlan(DateTimeOffset.UtcNow.AddDays(7), "الرمال");
    }

    private async Task SubmitConflictPlan()
    {
        await SubmitPlan(DateTimeOffset.UtcNow.AddHours(24), "الرمال");
    }

    private async Task SubmitPlan(DateTimeOffset scheduledDate, string sector)
    {
        var organization = await Db.Organizations
            .AsNoTracking()
            .OrderBy(x => x.Id)
            .FirstOrDefaultAsync();

        if (organization is null)
        {
            Accepted = false;
            ResultMessage = "لا توجد مؤسسة مسجلة بعد. ابدأ من بوابة الدخول وأنشئ مؤسسة رسمية أولاً.";
            return;
        }

        var result = await ConflictDetection.SubmitPlanAsync(new(
            AidKind.FoodBasket,
            scheduledDate,
            31.501m,
            34.466m,
            sector,
            250,
            organization.Id));

        Accepted = result.Accepted;
        ResultMessage = result.Message;
    }
}
