@page "/org/register"
@layout MainLayout
@inject NavigationManager Navigation

<PageTitle>نقطة - تسجيل مؤسسة</PageTitle>
<section class="entry-gateway auth-entry" dir="rtl"><div class="entry-brand"><span>ن</span><div><strong>نقطة</strong><small>مركز تنسيق الإغاثة</small></div></div><section class="entry-panel auth-panel"><div class="panel-title"><span class="eyebrow">انضمام المؤسسات</span><h1>أنشئ مساحة مؤسستك</h1><p>سجّل بيانات المؤسسة الرسمية لتبدأ إدارة خطط الإغاثة بعد اعتماد الحساب.</p></div><div class="gateway-card"><form method="post" action="/auth/org/register"><label for="org-name">اسم المؤسسة</label><input id="org-name" name="ngoName" placeholder="الاسم الرسمي للمؤسسة" required /><label for="org-license">رقم الترخيص</label><input id="org-license" name="licenseId" placeholder="رقم الترخيص الرسمي" required /><label for="org-person">الشخص المخوّل</label><input id="org-person" name="authorizedPerson" placeholder="اسم المسؤول المخوّل" required /><label for="org-passcode">رمز الدخول</label><input id="org-passcode" name="passcode" type="password" placeholder="6 خانات على الأقل" required minlength="6" /><label for="org-confirm-passcode">تأكيد رمز الدخول</label><input id="org-confirm-passcode" name="confirmPasscode" type="password" placeholder="أعد إدخال رمز الدخول" required oninput="if(this.value!=this.form.passcode.value)this.setCustomValidity('رمز الدخول غير متطابق');else this.setCustomValidity('')" /><button type="submit">إنشاء حساب المؤسسة <span>←</span></button></form>@if (Navigation.Uri.Contains("error=")) { <div class="result-box warning">تعذر إنشاء الحساب. تحقق من البيانات أو من أن رقم الترخيص غير مسجل مسبقاً.</div> }<p class="auth-switch">لديك حساب بالفعل؟ <a href="/org/login">تسجيل الدخول</a></p><p class="auth-switch"><a href="/">العودة إلى بوابة الدخول</a></p></div></section></section>
