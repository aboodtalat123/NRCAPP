@page "/volunteers"

<PageTitle>نقطة - المتطوعون</PageTitle>

<section class="feature-page volunteers-page" dir="rtl">
    <div class="feature-map volunteer-map">
        <span class="volunteer-pin one">مياه</span>
        <span class="volunteer-pin two">غذاء</span>
        <span class="volunteer-pin three">طبي</span>
    </div>

    <div class="feature-phone">
        <div class="phone-header">نقطة - الموارد والتحقق الميداني</div>
        <div class="feature-card primary">
            <h2>تأكيد تسليم الميدان</h2>
            <p>إدخال المخزون ونوع الحاجة من نقطة التوزيع، مع حفظ محلي عند ضعف الاتصال.</p>
            <div class="field-row"><span>الموقع الحالي</span><b>مخيم جباليا</b></div>
            <div class="field-row"><span>نوع الحاجة</span><b>مياه وغذاء</b></div>
            <button type="button">تنفيذ تأكيد التسليم</button>
        </div>
    </div>

    <aside class="feature-aside">
        <h2>قائمة المتطوعين</h2>
        <div class="volunteer-list">
            <p><b>ليان</b><span>متصل</span></p>
            <p><b>أحمد</b><span>آخر مزامنة 09:21</span></p>
            <p><b>سارة</b><span>في الطريق</span></p>
        </div>
    </aside>
</section>
