@page "/volunteers"
@rendermode InteractiveServer
@inject ReliefDbContext Db

<PageTitle>نقطة - المتطوعون</PageTitle>

<section class="feature-page volunteers-page" dir="rtl">
    <div class="role-header volunteer-hero">
        <div><span class="eyebrow">فريق التنفيذ</span><h2>إدارة المتطوعين بسهولة</h2><p>أضف أعضاء الفريق، وزّعهم حسب القطاع، وتابع جاهزيتهم من شاشة واحدة.</p></div>
        <div class="hero-stat"><strong>@VolunteerList.Count</strong><span>متطوع مسجل</span></div>
    </div>

    <section class="admin-content-grid volunteer-layout">
        <article class="admin-panel volunteer-form-panel">
            <div class="admin-panel-title"><span class="panel-kicker">إضافة سريعة</span><h2>إضافة متطوع جديد</h2><p>أدخل البيانات الأساسية ثم اضغط حفظ.</p></div>
            <div class="gateway-card volunteer-form">
                <label for="vol-name">الاسم الكامل</label>
                <input id="vol-name" @bind="NewName" placeholder="مثال: أحمد محمد" autocomplete="name" />
                <label for="vol-phone">رقم الهاتف</label>
                <input id="vol-phone" @bind="NewPhone" placeholder="05XXXXXXXX" inputmode="tel" autocomplete="tel" />
                <label for="vol-sector">القطاع</label>
                <select id="vol-sector" @bind="NewSector">@foreach (var sector in Sectors) { <option value="@sector">@sector</option> }</select>
                <button type="button" class="primary-action" @onclick="AddVolunteer" disabled="@IsAdding">
                    <span class="button-label">@(IsAdding ? "جارٍ الحفظ..." : "حفظ المتطوع")</span><span class="button-arrow">←</span>
                </button>
                @if (!string.IsNullOrWhiteSpace(AddMessage)) { <div class="result-box @(AddSuccess ? "success" : "warning")" role="status">@AddMessage</div> }
            </div>
        </article>

        <article class="admin-panel volunteer-list-panel">
            <div class="admin-panel-title"><span class="panel-kicker">سجل الفريق</span><h2>المتطوعون المسجلون</h2><p>آخر الإضافات تظهر في أعلى القائمة.</p></div>
            <div class="plans-table volunteer-table">
                <div class="table-head"><span>الاسم</span><span>الهاتف</span><span>القطاع</span><span>الحالة</span><span>تاريخ الانضمام</span></div>
                @foreach (var volunteer in VolunteerList)
                {
                    <div class="table-row"><span class="volunteer-name">@volunteer.FullName</span><span>@volunteer.PhoneNumber</span><span>@volunteer.Sector</span><span><span class="pill @(volunteer.IsActive ? "pill-active" : "pill-pending")">@(volunteer.IsActive ? "نشط" : "غير نشط")</span></span><span>@volunteer.JoinedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></div>
                }
                @if (VolunteerList.Count == 0) { <p class="empty-state">لا يوجد متطوعون مسجلون بعد.</p> }
            </div>
        </article>
    </section>
</section>

@code {
    private string NewName { get; set; } = "";
    private string NewPhone { get; set; } = "";
    private string NewSector { get; set; } = "الرمال";
    private string AddMessage { get; set; } = "";
    private bool AddSuccess { get; set; }
    private bool IsAdding { get; set; }
    private List<Volunteer> VolunteerList { get; set; } = [];
    private string[] Sectors { get; } = ["الرمال", "جباليا", "خان يونس", "دير البلح", "رفح"];

    protected override async Task OnInitializedAsync() { await LoadVolunteerList(); }

    private async Task LoadVolunteerList()
    {
        VolunteerList = await Db.Volunteers.AsNoTracking().OrderByDescending(x => x.JoinedAt).ToListAsync();
    }

    private async Task AddVolunteer()
    {
        if (IsAdding) return;
        AddMessage = ""; AddSuccess = false;
        if (string.IsNullOrWhiteSpace(NewName) || string.IsNullOrWhiteSpace(NewPhone)) { AddMessage = "اكتب اسم المتطوع ورقم الهاتف أولاً."; return; }
        IsAdding = true;
        try
        {
            Db.Volunteers.Add(new Volunteer { FullName = NewName.Trim(), PhoneNumber = NewPhone.Trim(), Sector = NewSector });
            await Db.SaveChangesAsync();
            NewName = ""; NewPhone = ""; AddSuccess = true; AddMessage = "تمت إضافة المتطوع بنجاح.";
            await LoadVolunteerList();
        }
        catch (Exception ex) { AddMessage = $"تعذر الحفظ: {ex.Message}"; }
        finally { IsAdding = false; }
    }
}
