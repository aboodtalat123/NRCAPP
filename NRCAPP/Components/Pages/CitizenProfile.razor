@page "/citizen/profile"
@attribute [Authorize(Policy = "CitizenOnly")]
@rendermode InteractiveServer
@inject ReliefDbContext Db
@inject IHttpContextAccessor HttpContextAccessor
@inject ILogger<CitizenProfile> Logger

<PageTitle>نقطة - ملف المواطن</PageTitle>

<section class="role-page citizen-profile-page" dir="rtl">
    <div class="role-header citizen citizen-profile-hero">
        <div><span class="eyebrow">مسار المواطن</span><h2>@CitizenName</h2><p>تابع المساعدات القريبة منك، واطلب التسجيل في الكوبونة المناسبة، ثم أكّد حضورك عند الموعد.</p></div>
        <div class="profile-chip"><span>رقم الهوية</span><strong>@(string.IsNullOrWhiteSpace(NationalId) ? "غير متوفر" : NationalId)</strong></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(PageMessage)) { <div class="result-box warning page-message" role="alert">@PageMessage</div> }

    <section class="citizen-summary-grid">
        <div class="summary-card"><span class="summary-icon">م</span><div><small>المنطقة الحالية</small><strong>@EffectiveSector</strong></div></div>
        <div class="summary-card"><span class="summary-icon gold">ك</span><div><small>طلبات التسجيل</small><strong>@RegisteredAid.Count</strong></div></div>
        <div class="summary-card"><span class="summary-icon blue">ق</span><div><small>توزيعات قريبة</small><strong>@LocalSchedule.Count</strong></div></div>
    </section>

    <section class="citizen-grid">
        <article class="form-panel citizen-card">
            <div class="panel-title"><span class="section-mark">١</span><div><span class="panel-kicker">خطوة واحدة</span><h3>اطلب التسجيل في كوبونة</h3><p>اختر المؤسسة المناسبة في قطاعك، وسنرسل طلبك مباشرة.</p></div></div>
            <div class="agency-list">
                @foreach (var agency in ActiveAgencies)
                {
                    var isProcessing = ProcessingOrgs.Contains(agency.OrganizationId);
                    <div class="agency-card">
                        <div class="agency-copy"><b>@agency.OrganizationName</b><span>@agency.ActivePlans خطة متاحة · أقرب مساعدة: @ToArabicAidType(agency.NextAidType)</span></div>
                        <button type="button" class="agency-action" @onclick="() => RequestEnrollment(agency.OrganizationId)" disabled="@isProcessing"><span>@(isProcessing ? "جارٍ الإرسال..." : "طلب التسجيل")</span><b>←</b></button>
                        @if (EnrollmentMessages.TryGetValue(agency.OrganizationId, out var message)) { <div class="enrollment-feedback @(message.StartsWith("تم") ? "success-text" : "")" role="status">@message</div> }
                    </div>
                }
                @if (ActiveAgencies.Count == 0) { <p class="empty-state">لا توجد كوبونات نشطة في قطاعك حالياً. ستظهر هنا تلقائياً عند اعتماد أول خطة.</p> }
            </div>
        </article>

        <article class="form-panel citizen-card">
            <div class="panel-title"><span class="section-mark">٢</span><div><span class="panel-kicker">حالتك الآن</span><h3>تسجيلاتك الحالية</h3><p>كل طلب مرتبط برقم هويتك ويمكنك متابعة حالته هنا.</p></div></div>
            <div class="timeline-list">
                @foreach (var item in RegisteredAid)
                {
                    <div class="timeline-item"><div><b>@item.OrganizationName · @ToArabicAidType(item.AidType)</b><span>@item.ScheduledDate.ToLocalTime().ToString("dd/MM · HH:mm")</span></div><small class="status-label">@ToArabicRegistrationStatus(item.Status)</small></div>
                }
                @if (RegisteredAid.Count == 0) { <p class="empty-state">لا توجد تسجيلات مؤكدة حتى الآن.</p> }
            </div>
        </article>

        <article class="plans-panel citizen-schedule citizen-card">
            <div class="panel-title"><span class="section-mark">٣</span><div><span class="panel-kicker">خلال ٢٤ ساعة</span><h3>مواعيد التوزيع في منطقتك</h3><p>إذا كان لديك طلب، أكّد حضورك ليتم حجز دورك.</p></div></div>
            <div class="plans-table citizen-plans-table">
                <div class="table-head"><span>المؤسسة</span><span>المساعدة</span><span>الموعد</span><span>الحضور</span><span>الإجراء</span></div>
                @foreach (var plan in LocalSchedule)
                {
                    <div class="table-row"><span>@plan.OrganizationName</span><span>@ToArabicAidType(plan.AidType)</span><span>@plan.ScheduledDate.ToLocalTime().ToString("dd/MM HH:mm")</span><span>@plan.ConfirmedAttendance / @plan.Capacity</span><span>@if (plan.MyStatus is RegistrationStatus.AttendanceConfirmed or RegistrationStatus.Delivered) { <span class="pill pill-active">@ToArabicRegistrationStatus(plan.MyStatus.Value)</span> } else if (plan.IsRegistered) { <button type="button" class="mini-button" @onclick="() => ConfirmAttendance(plan.DistributionPlanId)">تأكيد الحضور</button> } else { <span class="pill pill-pending">اطلب التسجيل أولاً</span> }</span></div>
                }
                @if (LocalSchedule.Count == 0) { <p class="empty-state">لا توجد توزيعات خلال ٢٤ ساعة في قطاعك.</p> }
            </div>
            @if (!string.IsNullOrWhiteSpace(AttendanceMessage)) { <div class="result-box success" role="status">@AttendanceMessage</div> }
        </article>
    </section>
</section>

@code {
    private string NationalId { get; set; } = "";

    private sealed record AgencyView(int OrganizationId, string OrganizationName, int ActivePlans, AidKind NextAidType);
    private sealed record RegistrationView(string OrganizationName, AidKind AidType, DateTimeOffset ScheduledDate, RegistrationStatus Status);
    private sealed record ScheduleView(int DistributionPlanId, string OrganizationName, AidKind AidType, DateTimeOffset ScheduledDate, int Capacity, int ConfirmedAttendance, bool IsRegistered, RegistrationStatus? MyStatus);

    private int BeneficiaryId { get; set; }
    private string CitizenName { get; set; } = "ملف المواطن";
    private string EffectiveSector { get; set; } = "غير محدد";
    private string? PageMessage { get; set; }
    private string? AttendanceMessage { get; set; }
    private List<AgencyView> ActiveAgencies { get; set; } = [];
    private List<RegistrationView> RegisteredAid { get; set; } = [];
    private List<ScheduleView> LocalSchedule { get; set; } = [];
    private Dictionary<int, string> EnrollmentMessages { get; set; } = [];
    private HashSet<int> ProcessingOrgs { get; set; } = [];
    private HashSet<int> ProcessingAttendance { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        NationalId = user?.FindFirst("national_id")?.Value ?? "";
        try { await LoadCitizenData(); }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load citizen profile for authenticated user");
            PageMessage = "تعذر تحميل بيانات الملف الآن. حاول مرة أخرى بعد قليل.";
        }
    }

    private async Task LoadCitizenData()
    {
        if (string.IsNullOrWhiteSpace(NationalId)) { CitizenName = "يرجى الدخول من بوابة المواطن"; EffectiveSector = "غير محدد"; return; }
        var beneficiary = await Db.Beneficiaries.AsNoTracking().SingleOrDefaultAsync(x => x.NationalId == NationalId.Trim());
        if (beneficiary is null) { CitizenName = "لم يتم العثور على المواطن"; PageMessage = "تأكد من رقم الهوية ثم أعد المحاولة."; return; }
        BeneficiaryId = beneficiary.Id; CitizenName = beneficiary.FullName; EffectiveSector = beneficiary.CurrentSector;
        var now = DateTimeOffset.UtcNow; var nextDay = now.AddHours(24);
        ActiveAgencies = await Db.DistributionPlans.AsNoTracking().Include(x => x.Organization).Where(x => x.TargetSector == EffectiveSector && x.Status == DistributionPlanStatus.Authorized && x.ScheduledDate >= now).GroupBy(x => new { x.OrganizationId, Name = x.Organization == null ? "مؤسسة غير معروفة" : x.Organization.NgoName }).Select(x => new AgencyView(x.Key.OrganizationId, x.Key.Name, x.Count(), x.OrderBy(p => p.ScheduledDate).Select(p => p.AidType).First())).ToListAsync();
        RegisteredAid = await Db.DistributionRegistrations.AsNoTracking().Include(x => x.DistributionPlan).ThenInclude(x => x!.Organization).Where(x => x.BeneficiaryId == BeneficiaryId).OrderBy(x => x.DistributionPlan!.ScheduledDate).Select(x => new RegistrationView(x.DistributionPlan!.Organization == null ? "مؤسسة غير معروفة" : x.DistributionPlan.Organization.NgoName, x.DistributionPlan.AidType, x.DistributionPlan.ScheduledDate, x.Status)).ToListAsync();
        LocalSchedule = await Db.DistributionPlans.AsNoTracking().Include(x => x.Organization).Include(x => x.Registrations).Where(x => x.TargetSector == EffectiveSector && x.Status == DistributionPlanStatus.Authorized && x.ScheduledDate >= now && x.ScheduledDate <= nextDay).OrderBy(x => x.ScheduledDate).Select(x => new ScheduleView(x.Id, x.Organization == null ? "مؤسسة غير معروفة" : x.Organization.NgoName, x.AidType, x.ScheduledDate, x.MaxBeneficiaryCapacity, x.Registrations.Count(r => r.Status == RegistrationStatus.AttendanceConfirmed || r.Status == RegistrationStatus.Delivered), x.Registrations.Any(r => r.BeneficiaryId == BeneficiaryId), x.Registrations.Where(r => r.BeneficiaryId == BeneficiaryId).Select(r => (RegistrationStatus?)r.Status).FirstOrDefault())).ToListAsync();
    }

    private async Task RequestEnrollment(int organizationId)
    {
        if (BeneficiaryId == 0 || !ProcessingOrgs.Add(organizationId)) return;
        try
        {
            var plan = await Db.DistributionPlans.Where(x => x.OrganizationId == organizationId && x.TargetSector == EffectiveSector && x.Status == DistributionPlanStatus.Authorized && x.ScheduledDate >= DateTimeOffset.UtcNow).OrderBy(x => x.ScheduledDate).FirstOrDefaultAsync();
            if (plan is null) { EnrollmentMessages[organizationId] = "لا توجد خطة متاحة لهذه المؤسسة في قطاعك حالياً."; return; }
            var exists = await Db.DistributionRegistrations.AnyAsync(x => x.BeneficiaryId == BeneficiaryId && x.DistributionPlanId == plan.Id);
            if (!exists) { Db.DistributionRegistrations.Add(new DistributionRegistration { BeneficiaryId = BeneficiaryId, DistributionPlanId = plan.Id, Status = RegistrationStatus.Requested }); await Db.SaveChangesAsync(); }
            EnrollmentMessages[organizationId] = exists ? "أنت مسجل مسبقاً في هذه الخطة." : "تم إرسال طلب التسجيل بنجاح.";
            await LoadCitizenData();
        }
        catch (Exception ex) { Logger.LogError(ex, "Enrollment request failed for organization {OrganizationId}", organizationId); EnrollmentMessages[organizationId] = "تعذر إرسال الطلب الآن. حاول مرة أخرى."; }
        finally { ProcessingOrgs.Remove(organizationId); }
    }

    private async Task ConfirmAttendance(int distributionPlanId)
    {
        if (BeneficiaryId == 0 || !ProcessingAttendance.Add(distributionPlanId)) return;
        try
        {
            var registration = await Db.DistributionRegistrations.FirstOrDefaultAsync(x => x.BeneficiaryId == BeneficiaryId && x.DistributionPlanId == distributionPlanId);
            if (registration is null) { AttendanceMessage = "اطلب التسجيل أولاً في هذه الخطة."; return; }
            registration.Status = RegistrationStatus.AttendanceConfirmed; registration.AttendanceConfirmedAt = DateTimeOffset.UtcNow; await Db.SaveChangesAsync();
            AttendanceMessage = "تم تأكيد حضورك وحجز دورك."; await LoadCitizenData();
        }
        catch (Exception ex) { Logger.LogError(ex, "Attendance confirmation failed for plan {PlanId}", distributionPlanId); AttendanceMessage = "تعذر تأكيد الحضور الآن. حاول مرة أخرى."; }
        finally { ProcessingAttendance.Remove(distributionPlanId); }
    }

    private static string ToArabicAidType(AidKind kind) => kind switch { AidKind.FoodBasket => "سلة غذائية", AidKind.SafeDrinkingWater => "مياه آمنة", AidKind.MedicalSupplies => "مستلزمات طبية", AidKind.ShelterKits => "حقائب إيواء", _ => kind.ToString() };
    private static string ToArabicRegistrationStatus(RegistrationStatus status) => status switch { RegistrationStatus.Requested => "قيد المراجعة", RegistrationStatus.Approved => "معتمد", RegistrationStatus.AttendanceConfirmed => "حضور مؤكد", RegistrationStatus.Delivered => "تم التسليم", RegistrationStatus.Rejected => "مرفوض", _ => status.ToString() };
}
