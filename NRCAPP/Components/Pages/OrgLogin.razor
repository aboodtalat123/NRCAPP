@page "/org/login"
@layout MainLayout
@inject NavigationManager Navigation

<PageTitle>نقطة - دخول مؤسسة</PageTitle>
<section class="entry-gateway auth-entry" dir="rtl">
    <div class="entry-brand"><span>ن</span><div><strong>نقطة</strong><small>مركز تنسيق الإغاثة</small></div></div>
    <section class="entry-panel auth-panel"><div class="panel-title"><span class="eyebrow">مسار المؤسسات</span><h1>دخول المؤسسة</h1><p>أدخل بيانات مؤسستك للوصول إلى خطط التوزيع ومتابعة التنفيذ.</p></div>
        <div class="gateway-card"><form method="post" action="/auth/org/form-login"><label for="org-license">رقم الترخيص</label><input id="org-license" name="licenseId" placeholder="أدخل رقم الترخيص" required /><label for="org-passcode">رمز الدخول</label><input id="org-passcode" type="password" name="passcode" placeholder="أدخل رمز الدخول" required />@if (ShowError) { <div class="result-box warning">@ErrorMessage</div> }<button type="submit">دخول إلى لوحة المؤسسة <span>←</span></button></form><p class="auth-switch">لا تملك حساباً؟ <a href="/org/register">سجّل مؤسسة جديدة</a></p><p class="auth-switch"><a href="/">العودة إلى بوابة الدخول</a></p></div>
    </section>
</section>
@code { private bool ShowError { get; set; } private string ErrorMessage { get; set; } = ""; protected override void OnInitialized() { if (new Uri(Navigation.Uri).Query.Contains("error=failed")) { ShowError = true; ErrorMessage = "رقم الترخيص أو رمز الدخول غير صحيح، أو أن الحساب غير معتمد."; } } }
